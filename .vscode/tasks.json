{
    // See https://go.microsoft.com/fwlink/?LinkId=733558
    // for the documentation about the tasks.json format
    "version": "2.0.0",
    "tasks": [
        {
            "label": "Clean",
            "type": "shell",
            "command": "./scripts/clean.bat",
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "presentation": {
                "echo": false,
                "reveal": "never",
                "showReuseMessage": false,
                "close": true,
            },
            "problemMatcher": []
        },
        {
            "label": "Update Template",
            "type": "shell",
            "command": "./scripts/update.bat",
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "presentation": {
                "reveal": "always",
                "panel": "dedicated",
                "clear": true
            },
            "args": [
                "/${input:abort}"
            ],
            "problemMatcher": []
        },
        {
            "label": "Install requirements",
            "type": "shell",
            "command": "./scripts/install.bat",
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "presentation": {
                "reveal": "always",
                "focus": true,
                "panel": "dedicated",
                "clear": true
            },
            "args": [
                "/installonly"
            ],
            "problemMatcher": []
        }
    ],
    "inputs": [
        {
            "id": "abort",
            "type": "pickString",
            "description": "Select a task execution option:",
            "options":[ "Run or Continue", "Abort" ],
            "default": "Run or Continue",
        },
    ]
}